{
	"name": "argosTesting",
	"version": "0.5.34",
	"private": false,
	"type": "module",
	"scripts": {
		"build": "node scripts/build.mjs",
		"dev": "node scripts/build.mjs --watch",
		"build:vsix": "node scripts/package.mjs",
		"package": "node scripts/package.mjs",
		"preview": "node scripts/build-preview.mjs",
		"preview:watch": "node scripts/build-preview.mjs --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"lint": "biome check src/"
	},
	"dependencies": {
		"@atconseil/argos-exporters": "workspace:^",
		"@atconseil/argos-gherkin": "workspace:*",
		"@atconseil/argos-importers": "workspace:^",
		"@atconseil/argos-sdk": "workspace:^",
		"@atconseil/argos-types": "workspace:^",
		"@atconseil/argos-wit-schema": "workspace:*",
		"@fluentui/react-components": "^9.54.0",
		"@monaco-editor/react": "^4.7.0",
		"azure-devops-extension-api": "^4.0.2",
		"azure-devops-extension-sdk": "^4.0.2",
		"monaco-editor": "^0.55.1",
		"react": "^19.2.6",
		"react-dom": "^18.3.0"
	},
	"devDependencies": {
		"@testing-library/react": "^16.0.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^18.3.0",
		"esbuild": "^0.28.0",
		"jsdom": "^29.1.1",
		"typescript": "^6.0.3",
		"vitest": "^3.1.0"
	}
}
