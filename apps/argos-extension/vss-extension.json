{
	"manifestVersion": 1,
	"id": "ArgosTesting",
	"publisher": "AlexThibaud",
	"version": "0.3.4",
	"name": "ArgosTesting",
	"description": "Industrial-grade test management for Azure DevOps — native Custom Work Items, AI-assisted, Cloud-only.",
	"targets": [{ "id": "Microsoft.VisualStudio.Services.Cloud" }],
	"categories": ["Azure Boards", "Azure Test Plans"],
	"icons": { "default": "static/marketplace-icon.png" },
	"scopes": [
		"vso.work_full",
		"vso.profile",
		"vso.code",
		"vso.extension.data_write",
		"vso.identity"
	],
	"contributions": [
		{
			"id": "argos-hub",
			"type": "ms.vss-web.hub",
			"description": "Argos Test Management Hub",
			"targets": ["ms.vss-web.project-hub-group"],
			"properties": {
				"name": "ArgosTesting",
				"order": 80,
				"uri": "dist/hub/hub.html",
				"iconUrl": "static/argos-hub.png"
			}
		},
		{
			"id": "argos-coverage-panel",
			"type": "ms.vss-work-web.work-item-form-page",
			"description": "Test Coverage panel shown on User Story, Bug, and Requirement Work Item forms — lists linked Test Cases with their latest execution status per environment.",
			"targets": ["ms.vss-work-web.work-item-form"],
			"properties": {
				"name": "Test Coverage",
				"uri": "dist/widgets/coverage-panel/index.html",
				"height": 400
			}
		}
	],
	"content": {
		"details": { "path": "overview.md" },
		"screenshots": [{ "path": "static/marketplace-banner.png" }]
	},
	"files": [{ "path": "dist", "addressable": true }, { "path": "static", "addressable": true }]
}
