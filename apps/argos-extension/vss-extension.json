{
	"manifestVersion": 1,
	"id": "argos-testvault",
	"publisher": "AlexThibaud",
	"version": "0.1.0",
	"name": "Argos",
	"description": "Xray-class test management for Azure DevOps — native Custom Work Items, AI-assisted, Cloud + Server 2022.",
	"public": true,
	"targets": [{ "id": "Microsoft.VisualStudio.Services" }],
	"categories": ["Azure Boards"],
	"scopes": ["vso.work"],
	"contributions": [
		{
			"id": "argos-hub",
			"type": "ms.vss-web.hub",
			"description": "Argos Test Management Hub",
			"targets": ["ms.vss-web.project-hub-group"],
			"properties": {
				"name": "Argos",
				"order": 99,
				"uri": "dist/hub/hub.html"
			}
		},
		{
			"id": "argos-coverage-panel",
			"type": "ms.vss-work-web.work-item-form-page",
			"description": "Test Coverage panel shown on User Story, Bug, and Requirement Work Item forms — lists linked Test Cases with their latest execution status per environment.",
			"targets": ["ms.vss-work-web.work-item-form"],
			"properties": {
				"name": "Test Coverage",
				"uri": "dist/hub/hub.html",
				"height": 300
			}
		}
	],
	"content": {
		"details": { "path": "overview.md" }
	},
	"files": [{ "path": "overview.md" }, { "path": "dist/hub", "addressable": true }]
}
