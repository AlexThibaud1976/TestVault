# Normalize line endings to LF on commit, checkout with native endings
* text=auto eol=lf

# Force LF for source files
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.toml    text eol=lf
*.html    text eol=lf
*.css     text eol=lf

# Binary files
*.vsix    binary
*.png     binary
*.jpg     binary
*.ico     binary
*.woff    binary
*.woff2   binary
